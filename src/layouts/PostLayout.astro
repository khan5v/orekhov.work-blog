---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  readingTime: number;
  nextPost?: { title: string; slug: string };
}

const { title, date, description, tags, readingTime, nextPost } = Astro.props;

const formatted = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalURL = Astro.url.href;
const defaultOgImage = new URL('/og-default.png', Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  url: canonicalURL,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL },
  image: defaultOgImage,
  wordCount: readingTime * 250,
  author: {
    '@type': 'Person',
    name: 'Vladimir Orekhov',
    url: 'https://orekhov.work/about/',
  },
  publisher: {
    '@type': 'Person',
    name: 'Vladimir Orekhov',
  },
};
---
<BaseLayout title={`${title} — orekhov.work`} description={description} ogType="article">
  <meta property="article:published_time" content={date.toISOString()} slot="head" />
  {tags.map(tag => <meta property="article:tag" content={tag} slot="head" />)}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article>
    <div class="article-header">
      <a href="/" class="back">&larr; All posts</a>
      <div class="label">
        {tags.map((tag, i) => (
          <a href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="label-link">{tag}{i < tags.length - 1 ? ' · ' : ''}</a>
        ))}
      </div>
      <h1>{title}</h1>
      <div class="article-meta">
        <time datetime={date.toISOString()}>{formatted}</time> &middot; {readingTime} min read
      </div>
    </div>

    <div class="article-body">
      <slot />
    </div>

    {nextPost && (
      <div class="next-post">
        <span class="next-label">Keep reading</span>
        <a href={`/posts/${nextPost.slug}/`} class="next-link">{nextPost.title} &rarr;</a>
      </div>
    )}
  </article>

</BaseLayout>

<style is:global>
  /* --- ARTICLE HEADER --- */
  .article-header {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3.5rem 1.5rem 0;
  }

  .article-header .back {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 2.5rem;
    transition: opacity 0.15s;
  }

  .article-header .back:hover { opacity: 0.7; }

  .article-header .label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .article-header .label-link {
    color: var(--accent);
    text-decoration: none;
  }

  .article-header .label-link:hover {
    text-decoration: underline;
  }

  .article-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .article-meta {
    font-size: 0.85rem;
    color: var(--text-secondary);
    padding-bottom: 2rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  /* --- ARTICLE BODY --- */
  .article-body {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .article-body p {
    margin-bottom: 1.15rem;
  }

  .article-body h2 {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-top: 1.85rem;
    margin-bottom: 0.65rem;
  }

  .article-body h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .article-body blockquote {
    background: var(--accent-subtle);
    border-left: 3px solid var(--accent);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 0 8px 8px 0;
    color: var(--text);
    font-size: 0.95rem;
  }

  .article-body pre {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    font-family: 'JetBrains Mono', 'SF Mono', 'Consolas', monospace;
    font-size: 0.82rem;
    line-height: 1.65;
    margin: 1.5rem 0;
  }

  .article-body code {
    font-family: 'JetBrains Mono', 'SF Mono', 'Consolas', monospace;
    font-size: 0.85em;
    background: var(--bg-surface);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .article-body pre code {
    background: none;
    padding: 0;
    border: none;
    font-size: inherit;
  }

  .article-body strong {
    font-weight: 600;
  }

  .article-body ul, .article-body ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .article-body li {
    margin-bottom: 0.5rem;
  }

  .article-body a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-body a:hover {
    opacity: 0.8;
  }

  .article-body img {
    max-width: 100%;
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .article-body hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  /* --- TABLES --- */
  .article-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .article-body th,
  .article-body td {
    padding: 0.6rem 1.1rem;
    border-bottom: 1px solid var(--border);
  }

  .article-body th {
    font-weight: 600;
    background: var(--bg-surface);
    border-bottom: 2px solid var(--border);
    text-align: left;
  }

  .article-body tbody tr:last-child td {
    border-bottom: none;
  }

  @media (max-width: 640px) {
    .article-body table {
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      font-size: 0.82rem;
    }

    .article-body th,
    .article-body td {
      padding: 0.45rem 0.7rem;
      white-space: nowrap;
    }
  }

  /* --- NEXT POST --- */
  .next-post {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 3rem;
    border-top: 1px solid var(--border);
  }

  .next-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .next-link {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .next-link:hover {
    color: var(--accent);
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 640px) {
    .article-header { padding: 2rem 1rem 0; }
    .article-header h1 { font-size: 1.9rem; }
    .article-body { padding: 0 1rem 3rem; font-size: 1rem; }
    .article-body pre { padding: 1rem; font-size: 0.75rem; }
    .next-post { padding: 1.5rem 1rem 2.5rem; }
  }
</style>
