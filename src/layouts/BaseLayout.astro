---
import { ViewTransitions } from 'astro:transitions';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalURL?: string;
}

const {
  title,
  description = 'Deep dives into distributed systems, database internals, and infrastructure — how things actually work under the hood.',
  ogImage,
  ogType = 'website',
  canonicalURL = Astro.url.href,
} = Astro.props;

const siteName = 'orekhov';
const defaultOgImage = new URL('/og-default.png', Astro.site).href;
const resolvedOgImage = ogImage || defaultOgImage;

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#FFFFFF" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#1C1C1C" media="(prefers-color-scheme: dark)" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:site_name" content="orekhov.work" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />



  <ViewTransitions />
  <slot name="head" />

  <!-- Prevent flash of wrong theme -->
  <script is:inline>
    (function() {
      const saved = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = saved || (prefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body>
  <nav>
    <a href="/" class="logo">{siteName}<span class="logo-dot"></span></a>
    <div class="nav-right">
      <a href="/posts/" class:list={[{ active: isActive('/posts/') }]}>Posts</a>
      <a href="/tags/" class:list={[{ active: isActive('/tags/') }]}>Tags</a>
      <a href="/about/" class:list={[{ active: isActive('/about/') }]}>About</a>
      <ThemeToggle />
    </div>
  </nav>

  <slot />

  <footer>&copy; {new Date().getFullYear()} &middot; {['Reviewed by exactly one person','Works on my machine','Written with coffee and regret','Eventually consistent','Uptime: mostly'][Math.floor(Math.random() * 5)]}</footer>
</body>
</html>

<style is:global>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --bg: #FFFFFF;
    --bg-surface: #F0F0F0;
    --text: #0D0D0D;
    --text-secondary: #737373;
    --accent: #2563EB;
    --accent-subtle: #EFF6FF;
    --border: #E5E5E5;
    --max-width: 740px;
  }

  [data-theme="dark"] {
    --bg: #1C1C1C;
    --bg-surface: #252525;
    --text: #CACACC;
    --text-secondary: #848488;
    --accent: #6CA4F0;
    --accent-subtle: #262630;
    --border: #333336;
  }

  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    font-family: 'Inter Variable', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    transition: background 0.25s, color 0.25s;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  /* --- NAV --- */
  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.75rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .logo-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
    margin-left: 2px;
    vertical-align: baseline;
  }

  .nav-right {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .nav-right a {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-right a:hover { color: var(--text); }

  .nav-right a.active {
    color: var(--text);
    padding-bottom: 2px;
    border-bottom: 1.5px solid var(--text);
  }

  .theme-toggle {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    color: var(--text);
    cursor: pointer;
    padding: 0.35rem 0.7rem;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    font-family: inherit;
    transition: background 0.15s;
  }

  .theme-toggle:hover { background: var(--border); }

  /* --- POST LIST --- */
  .posts {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .posts-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--text);
    margin-bottom: 0;
  }

  .posts-header h2 {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .posts-header span {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .post-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .post-date-col {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-top: 0.2rem;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }

  .post-reading-time {
    font-size: 0.75rem;
    color: var(--text-secondary);
    opacity: 0.7;
  }

  .post-content h3 {
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.015em;
    margin-bottom: 0.4rem;
  }

  .post-content h3 a {
    color: var(--text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-content h3 a:hover { color: var(--accent); }

  .post-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 0.6rem;
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-subtle);
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .tag:hover { opacity: 0.8; }

  /* --- FOOTER --- */
  footer {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-align: center;
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 640px) {
    .posts { padding: 0 1rem; }

    .post-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .post-date { padding-top: 0; }

    nav { padding: 1.25rem 1rem; }
    .nav-right { gap: 0.75rem; }
    footer { padding: 1.5rem 1rem; }
  }
</style>
