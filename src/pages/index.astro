---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = allPosts.slice(0, 5);
const hasMore = allPosts.length > 5;

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'orekhov.work',
  url: 'https://orekhov.work',
  description: 'Engineering blog containing practical deep dives into databases, distributed systems, and infrastructure — explained from first principles.',
  author: {
    '@type': 'Person',
    name: 'Vladimir Orekhov',
    url: 'https://orekhov.work/about/',
    sameAs: ['https://www.linkedin.com/in/orekhov/'],
  },
};
---
<BaseLayout title="orekhov.work — Engineering Blog" description="Practical deep dives into database internals, distributed systems, and infrastructure — how things actually work under the hood, explained from first principles.">
  <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
  <div class="hero">
    <div class="label">Engineering Blog</div>
    <h1>Building systems<br />that survive<br />production.</h1>
    <p>Deep dives into distributed systems, database internals, and the infrastructure that powers real-world software — how things actually work under the hood, explained the way I wish someone had explained them to me.</p>
  </div>

  <div class="posts">
    <div class="posts-header">
      <h2>Recent posts</h2>
    </div>

    {posts.map((post) => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        description={post.data.description}
        tags={post.data.tags}
        slug={post.id}
        readingTime={Math.max(1, Math.ceil((post.body?.split(/\s+/).length ?? 0) / 250))}
      />
    ))}

    {hasMore && (
      <a href="/posts/" class="view-all">View all {allPosts.length} posts &rarr;</a>
    )}
  </div>
</BaseLayout>

<style>
  .hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem 1.5rem 3rem;
  }

  .hero .label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .hero h1 {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.035em;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 520px;
    line-height: 1.6;
  }

  .view-all {
    display: block;
    text-align: center;
    padding: 1.5rem 0;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .view-all:hover { opacity: 0.7; }

  @media (max-width: 640px) {
    .hero { padding: 2.5rem 1rem 2rem; }
    .hero h1 { font-size: 2.2rem; }
  }
</style>
