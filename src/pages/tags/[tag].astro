---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  // Build slug → original tag name map (preserves casing like "ClickHouse")
  const tagMap = new Map<string, string>();
  posts.flatMap((post) => post.data.tags).forEach((t) => {
    const slug = t.toLowerCase().replace(/\s+/g, '-');
    if (!tagMap.has(slug)) tagMap.set(slug, t);
  });

  return [...tagMap.keys()].map((tag) => ({
    params: { tag },
    props: {
      displayTag: tagMap.get(tag)!,
      posts: posts
        .filter((post) => post.data.tags.map((t) => t.toLowerCase().replace(/\s+/g, '-')).includes(tag) && !post.data.draft)
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { displayTag, posts } = Astro.props;
---
<BaseLayout title={`${displayTag} — orekhov.work`} description={`Articles about ${displayTag} — deep dives into how things actually work, explained from first principles.`}>
  <div class="tag-page">
    <a href="/" class="back">&larr; All posts</a>
    <div class="label">Tag</div>
    <h1>{displayTag}</h1>
    <p class="count">{posts.length} {posts.length === 1 ? 'article' : 'articles'}</p>
  </div>

  <div class="posts">
    {posts.map((post) => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        description={post.data.description}
        tags={post.data.tags}
        slug={post.id}
        readingTime={Math.max(1, Math.ceil((post.body?.split(/\s+/).length ?? 0) / 250))}
      />
    ))}
  </div>
</BaseLayout>

<style>
  .tag-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3.5rem 1.5rem 2rem;
  }

  .back {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 2.5rem;
    transition: opacity 0.15s;
  }

  .back:hover { opacity: 0.7; }

  .label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .count {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  @media (max-width: 640px) {
    .tag-page { padding: 2rem 1rem 1.5rem; }
    h1 { font-size: 1.9rem; }
  }
</style>
